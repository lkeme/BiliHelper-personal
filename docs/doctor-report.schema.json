{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lkeme/BiliHelper-personal/docs/doctor-report.schema.json",
  "title": "BiliHelper Personal Doctor Report",
  "type": "object",
  "required": [
    "profiles",
    "runtime_summary",
    "request_summary",
    "request_providers",
    "request_traffic",
    "plugin_failures",
    "scheduler_issues"
  ],
  "properties": {
    "profiles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stringMap"
      }
    },
    "runtime_summary": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stringMap"
      }
    },
    "request_summary": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stringMap"
      }
    },
    "request_providers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stringMap"
      }
    },
    "request_traffic": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stringMap"
      }
    },
    "plugin_failures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stringMap"
      }
    },
    "scheduler_issues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stringMap"
      }
    }
  },
  "$defs": {
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
